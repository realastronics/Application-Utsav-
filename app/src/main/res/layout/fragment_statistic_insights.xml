<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Utsav"
            android:textSize="26sp"
            android:textColor="#9381FF"
            android:fontFamily="@font/poppins_bold"
            android:textStyle="bold"/>

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_menu"
            android:scaleType="fitCenter"
            app:tint="#333333"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FD">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="100dp">

            <!-- PROFILE VIEWS CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_eye"
                            android:padding="10dp"
                            android:background="@drawable/bg_value_box"
                            android:backgroundTint="#F0EEFF"
                            app:tint="#9381FF"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:text="+12%"
                            android:textColor="#9381FF"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_semibold"/>
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tvProfileViewsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profile Views"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/dm_sans"/>

                    <TextView
                        android:id="@+id/tvProfileViews"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1,284"
                        android:textColor="#111111"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SMALL CARDS ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_chat"
                                android:padding="8dp"
                                android:background="@drawable/bg_value_box"
                                android:backgroundTint="#809381FF"
                                app:tint="#FFFFFF"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentRight="true"
                                android:text="+5%"
                                android:textColor="#111111"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_semibold"/>
                        </RelativeLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Request"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/dm_sans"/>
                        <TextView
                            android:id="@+id/tvTotalRequestCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45"
                            android:textColor="#111111"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_bolt"
                                android:padding="8dp"
                                android:background="@drawable/bg_value_box"
                                android:backgroundTint="#D0D0FF"
                                app:tint="#111111"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentRight="true"
                                android:text="+0.8%"
                                android:textColor="#111111"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_semibold"/>
                        </RelativeLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Engagement"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/dm_sans"/>
                        <TextView
                            android:id="@+id/tvEngagementRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4.8%"
                            android:textColor="#111111"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- REACH CHART CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Profile Reach (Last 30 days)"
                                android:textColor="#888888"
                                android:textSize="13sp"
                                android:fontFamily="@font/dm_sans"/>
                            <TextView
                                android:id="@+id/tvProfileReach"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="24,512"
                                android:textColor="#111111"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/poppins_bold"/>
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:text="↗ 15.4%"
                            android:textColor="#9381FF"
                            android:textSize="12sp"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:background="@drawable/bg_value_box"
                            android:backgroundTint="#F0EEFF"
                            android:fontFamily="@font/poppins_semibold"/>
                    </RelativeLayout>

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="20dp"
                        android:src="@drawable/bg_wave_chart"
                        android:scaleType="fitXY"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="WEEK 1" android:textSize="10sp" android:textColor="#888888" android:gravity="center" android:fontFamily="@font/dm_sans"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="WEEK 2" android:textSize="10sp" android:textColor="#888888" android:gravity="center" android:fontFamily="@font/dm_sans"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="WEEK 3" android:textSize="10sp" android:textColor="#888888" android:gravity="center" android:fontFamily="@font/dm_sans"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="WEEK 4" android:textSize="10sp" android:textColor="#888888" android:gravity="center" android:fontFamily="@font/dm_sans"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Service Breakdown"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginBottom="16dp"/>

            <!-- SERVICE ITEMS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_event"
                        android:padding="10dp"
                        android:background="@drawable/bg_value_box"
                        android:backgroundTint="#B0B0FF"
                        app:tint="#FFFFFF"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Corporate Events"
                            android:textColor="#111111"
                            android:textSize="15sp"
                            android:fontFamily="@font/poppins_semibold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="42 bookings this month"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:fontFamily="@font/dm_sans"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45%"
                            android:textColor="#111111"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_bold"/>
                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="60dp"
                            android:layout_height="4dp"
                            android:progress="45"
                            android:progressTint="#B0B0FF"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_party"
                        android:padding="10dp"
                        android:background="@drawable/bg_value_box"
                        android:backgroundTint="#B0B0FF"
                        app:tint="#111111"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Private Parties"
                            android:textColor="#111111"
                            android:textSize="15sp"
                            android:fontFamily="@font/poppins_semibold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="28 bookings this month"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:fontFamily="@font/dm_sans"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="30%"
                            android:textColor="#111111"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_bold"/>
                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="60dp"
                            android:layout_height="4dp"
                            android:progress="30"
                            android:progressTint="#666666"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_person"
                        android:padding="10dp"
                        android:background="@drawable/bg_value_box"
                        android:backgroundTint="#B0B0FF"
                        app:tint="#FFFFFF"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Consultations"
                            android:textColor="#111111"
                            android:textSize="15sp"
                            android:fontFamily="@font/poppins_semibold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15 bookings this month"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:fontFamily="@font/dm_sans"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="25%"
                            android:textColor="#111111"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_bold"/>
                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="60dp"
                            android:layout_height="4dp"
                            android:progress="25"
                            android:progressTint="#B0B0FF"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
