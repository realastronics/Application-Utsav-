<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ====== TOP BAR ====== -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_alignParentTop="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Utsav"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#7C5CBF"
            android:fontFamily="serif"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_menu"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#1A1A2E"
            android:contentDescription="Menu"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true" />
    </RelativeLayout>

    <!-- Page title bar -->
    <RelativeLayout
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/topBar"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#1A1A2E"
            android:contentDescription="Back"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notifications"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_centerInParent="true" />

        <ImageButton
            android:id="@+id/btnMarkAllRead"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_check_all"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#7C5CBF"
            android:contentDescription="Mark all read"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true" />
    </RelativeLayout>

    <!-- Tab bar -->
    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_below="@id/titleBar"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView android:id="@+id/tabAll"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:text="All" android:textSize="14sp" android:textColor="#7C5CBF"
            android:textStyle="bold" android:gravity="center"
            android:paddingEnd="24dp" android:background="@null"/>

        <TextView android:id="@+id/tabActivity"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:text="Activity" android:textSize="14sp" android:textColor="#757575"
            android:gravity="center" android:paddingEnd="24dp" android:background="@null"/>

        <TextView android:id="@+id/tabSystem"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:text="System" android:textSize="14sp" android:textColor="#757575"
            android:gravity="center" android:background="@null"/>
    </LinearLayout>

    <!-- Tab indicator -->
    <View
        android:id="@+id/tabIndicator"
        android:layout_width="28dp"
        android:layout_height="2dp"
        android:layout_below="@id/tabBar"
        android:layout_marginStart="16dp"
        android:background="#7C5CBF"/>

    <!-- Tab divider -->
    <View
        android:id="@+id/tabDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/tabBar"
        android:background="#E0E0E0"/>

    <!-- ====== BOTTOM NAV ====== -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:src="@drawable/ic_home" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#BDBDBD" android:contentDescription="Home"/>
        <ImageButton android:id="@+id/navRequests"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:src="@drawable/ic_requests" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#BDBDBD" android:contentDescription="Requests"/>
        <ImageButton android:id="@+id/navStats"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:src="@drawable/ic_stats" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#7C5CBF" android:contentDescription="Stats"/>
        <ImageButton android:id="@+id/navChat"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:src="@drawable/ic_chat" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#BDBDBD" android:contentDescription="Chat"/>
        <ImageButton android:id="@+id/navProfile"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:src="@drawable/ic_profile" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#BDBDBD" android:contentDescription="Profile"/>
    </LinearLayout>

    <!-- ====== NOTIFICATION LIST ====== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tabDivider"
        android:layout_above="@id/bottomNav"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="12dp">

            <!-- TODAY -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Today" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#1A1A2E" android:layout_marginBottom="10dp"/>

            <!-- Card: Event Confirmed -->
            <androidx.cardview.widget.CardView android:id="@+id/cardEventConfirmed"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp" app:cardElevation="0dp"
                app:cardBackgroundColor="#EDE7F6">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="14dp">
                    <ImageView android:id="@+id/iconEvent"
                        android:layout_width="42dp" android:layout_height="42dp"
                        android:src="@drawable/ic_eye"
                        android:background="@drawable/circle_white_bg"
                        android:padding="9dp" android:tint="#7C5CBF"
                        android:layout_centerVertical="true" android:layout_alignParentStart="true"
                        android:contentDescription="Event"/>
                    <TextView android:id="@+id/tvEventTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Event Confirmed" android:textSize="14sp" android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_toEndOf="@id/iconEvent" android:layout_marginStart="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2m ago" android:textSize="11sp" android:textColor="#757575"
                        android:layout_alignParentEnd="true" android:layout_alignTop="@id/tvEventTitle"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="A client booked corporate event is confirmed"
                        android:textSize="12sp" android:textColor="#5D4B8C"
                        android:layout_below="@id/tvEventTitle"
                        android:layout_toEndOf="@id/iconEvent"
                        android:layout_marginStart="12dp" android:layout_marginTop="2dp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Message Received 1 -->
            <androidx.cardview.widget.CardView android:id="@+id/cardMessageReceived1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp" app:cardElevation="0dp"
                app:cardBackgroundColor="#EDE7F6">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="14dp">
                    <ImageView android:id="@+id/iconMsg1"
                        android:layout_width="42dp" android:layout_height="42dp"
                        android:src="@drawable/ic_mail"
                        android:background="@drawable/circle_white_bg"
                        android:padding="9dp" android:tint="#7C5CBF"
                        android:layout_centerVertical="true" android:layout_alignParentStart="true"
                        android:contentDescription="Message"/>
                    <TextView android:id="@+id/tvMsg1Title"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Message Recieved" android:textSize="14sp" android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_toEndOf="@id/iconMsg1" android:layout_marginStart="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="15m ago" android:textSize="11sp" android:textColor="#757575"
                        android:layout_alignParentEnd="true" android:layout_alignTop="@id/tvMsg1Title"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Amit sent an inquiry regarding your availability on 13th March."
                        android:textSize="12sp" android:textColor="#5D4B8C"
                        android:layout_below="@id/tvMsg1Title"
                        android:layout_toEndOf="@id/iconMsg1"
                        android:layout_marginStart="12dp" android:layout_marginTop="2dp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Subscription Expiration -->
            <androidx.cardview.widget.CardView android:id="@+id/cardSubscription"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp" app:cardElevation="0dp"
                app:cardBackgroundColor="#EDE7F6">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="14dp">
                    <ImageView android:id="@+id/iconSub"
                        android:layout_width="42dp" android:layout_height="42dp"
                        android:src="@drawable/ic_stats"
                        android:background="@drawable/circle_white_bg"
                        android:padding="9dp" android:tint="#7C5CBF"
                        android:layout_centerVertical="true" android:layout_alignParentStart="true"
                        android:contentDescription="Subscription"/>
                    <TextView android:id="@+id/tvSubTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Subscription Expiration" android:textSize="14sp"
                        android:textStyle="bold" android:textColor="#1A1A2E"
                        android:layout_toEndOf="@id/iconSub" android:layout_marginStart="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1h ago" android:textSize="11sp" android:textColor="#757575"
                        android:layout_alignParentEnd="true" android:layout_alignTop="@id/tvSubTitle"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Your PRO subscription will expire soon."
                        android:textSize="12sp" android:textColor="#5D4B8C"
                        android:layout_below="@id/tvSubTitle"
                        android:layout_toEndOf="@id/iconSub"
                        android:layout_marginStart="12dp" android:layout_marginTop="2dp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- YESTERDAY -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Yesterday" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#1A1A2E" android:layout_marginBottom="10dp"/>

            <!-- Card: Message Received 2 -->
            <androidx.cardview.widget.CardView android:id="@+id/cardMessageReceived2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp" app:cardElevation="0dp"
                app:cardBackgroundColor="#EDE7F6">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="14dp">
                    <ImageView android:id="@+id/iconMsg2"
                        android:layout_width="42dp" android:layout_height="42dp"
                        android:src="@drawable/ic_mail"
                        android:background="@drawable/circle_white_bg"
                        android:padding="9dp" android:tint="#7C5CBF"
                        android:layout_centerVertical="true" android:layout_alignParentStart="true"
                        android:contentDescription="Message"/>
                    <TextView android:id="@+id/tvMsg2Title"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Message Recieved" android:textSize="14sp" android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_toEndOf="@id/iconMsg2" android:layout_marginStart="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="15h ago" android:textSize="11sp" android:textColor="#757575"
                        android:layout_alignParentEnd="true" android:layout_alignTop="@id/tvMsg2Title"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Amit sent an inquiry regarding your availability on 13th March."
                        android:textSize="12sp" android:textColor="#5D4B8C"
                        android:layout_below="@id/tvMsg2Title"
                        android:layout_toEndOf="@id/iconMsg2"
                        android:layout_marginStart="12dp" android:layout_marginTop="2dp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>