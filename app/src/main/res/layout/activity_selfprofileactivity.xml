<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ====== TOP BAR ====== -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_alignParentTop="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Utsav"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#7C5CBF"
            android:fontFamily="serif"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_menu"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#1A1A2E"
            android:contentDescription="Menu"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true" />
    </RelativeLayout>

    <!-- ====== BOTTOM NAV ====== -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:src="@drawable/ic_home" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#BDBDBD" android:contentDescription="Home"/>
        <ImageButton android:id="@+id/navRequests"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:src="@drawable/ic_requests" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#BDBDBD" android:contentDescription="Requests"/>
        <ImageButton android:id="@+id/navStats"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:src="@drawable/ic_stats" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#BDBDBD" android:contentDescription="Stats"/>
        <ImageButton android:id="@+id/navChat"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:src="@drawable/ic_chat" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#BDBDBD" android:contentDescription="Chat"/>
        <ImageButton android:id="@+id/navProfile"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:src="@drawable/ic_profile" android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#7C5CBF" android:contentDescription="Profile"/>
    </LinearLayout>

    <!-- ====== SCROLLABLE CONTENT ====== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@id/bottomNav"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="16dp"
                android:paddingBottom="20dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivProfilePhoto"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/ic_profile_placeholder"
                    app:civ_border_width="3dp"
                    app:civ_border_color="#EDE7F6"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvManagerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Farhan Akhter"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvManagerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Senior Event Manager"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="18dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_location_pin"
                        android:tint="#7C5CBF"
                        android:layout_marginEnd="4dp"
                        android:contentDescription="Location" />

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New Delhi, IND"
                        android:textSize="12sp"
                        android:textColor="#757575" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btnEditProfile"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Edit Profile"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#7C5CBF"
                        android:layout_marginEnd="10dp"
                        app:cornerRadius="20dp" />

                    <Button
                        android:id="@+id/btnShare"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Share"
                        android:textSize="13sp"
                        android:textColor="#7C5CBF"
                        android:backgroundTint="#EDE7F6"
                        app:cornerRadius="20dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginBottom="20dp"/>

            <!-- Specialization -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Specialization"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">

                    <TextView android:id="@+id/chipCorporate"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="Corporate Galas" android:textSize="12sp" android:textColor="#7C5CBF"
                        android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/chip_purple_outline" android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/chipWeddings"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="Weddings" android:textSize="12sp" android:textColor="#7C5CBF"
                        android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/chip_purple_outline"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/chipTech"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="Tech Conferences" android:textSize="12sp" android:textColor="#7C5CBF"
                        android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/chip_purple_outline" android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/chipPrivate"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="Private Parties" android:textSize="12sp" android:textColor="#7C5CBF"
                        android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/chip_purple_outline"/>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginBottom="20dp"/>

            <!-- Portfolio -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Portfolio" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="#1A1A2E"/>
                    <TextView android:id="@+id/tvViewAll"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="View All" android:textSize="13sp" android:textColor="#7C5CBF"
                        android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
                </RelativeLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="4dp">
                    <ImageView android:id="@+id/portfolioImg1"
                        android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1"
                        android:scaleType="centerCrop" android:background="#EDE7F6"
                        android:layout_marginEnd="4dp" android:contentDescription="Portfolio 1"/>
                    <ImageView android:id="@+id/portfolioImg2"
                        android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1"
                        android:scaleType="centerCrop" android:background="#D1C4E9"
                        android:layout_marginEnd="4dp" android:contentDescription="Portfolio 2"/>
                    <ImageView android:id="@+id/portfolioImg3"
                        android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1"
                        android:scaleType="centerCrop" android:background="#B39DDB"
                        android:contentDescription="Portfolio 3"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView android:id="@+id/portfolioImg4"
                        android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1"
                        android:scaleType="centerCrop" android:background="#9575CD"
                        android:layout_marginEnd="4dp" android:contentDescription="Portfolio 4"/>
                    <ImageView android:id="@+id/portfolioImg5"
                        android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1"
                        android:scaleType="centerCrop" android:background="#7E57C2"
                        android:layout_marginEnd="4dp" android:contentDescription="Portfolio 5"/>
                    <ImageView android:id="@+id/portfolioImg6"
                        android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1"
                        android:scaleType="centerCrop" android:background="#673AB7"
                        android:contentDescription="Portfolio 6"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>