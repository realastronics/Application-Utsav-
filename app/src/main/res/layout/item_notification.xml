<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#EDEBFF">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- 🔵 Icon -->
        <ImageView
            android:id="@+id/ivNotifIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:background="@drawable/bg_circle_white"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_notifications" />

        <!-- 🔴 Unread dot -->
        <View
            android:id="@+id/dotUnread"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_alignTop="@id/ivNotifIcon"
            android:layout_alignEnd="@id/ivNotifIcon"
            android:layout_margin="2dp"
            android:background="@drawable/bg_circle_white" />

        <!-- 🟣 Title -->
        <TextView
            android:id="@+id/tvNotifTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/ivNotifIcon"
            android:layout_marginStart="12dp"
            android:layout_alignTop="@id/ivNotifIcon"
            android:text="Title"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="14sp" />

        <!-- ⏱ Time -->
        <TextView
            android:id="@+id/tvNotifTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignBaseline="@id/tvNotifTitle"
            android:layout_alignParentEnd="true"
            android:text="2m ago"
            android:textSize="12sp"
            android:textColor="#666666" />

        <!-- 🧾 Body -->
        <TextView
            android:id="@+id/tvNotifBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvNotifTitle"
            android:layout_toEndOf="@id/ivNotifIcon"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:text="Notification body text goes here"
            android:textColor="#444444"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"/>

    </RelativeLayout>

</androidx.cardview.widget.CardView>