<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══════════════════ MAIN CONTENT ═══════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F8F6FF">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <!-- ── PURPLE HERO ────────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#7C5CBF"
                    android:orientation="vertical"
                    android:paddingBottom="28dp">

                    <!-- Top bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Utsav"
                            android:textSize="26sp"
                            android:textColor="#FFFFFF"
                            android:fontFamily="@font/poppins_bold"
                            android:textStyle="bold"/>

                        <ImageView
                            android:id="@+id/btnMenu"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_menu"
                            android:scaleType="fitCenter"
                            android:contentDescription="Menu"
                            app:tint="#FFFFFF"/>

                    </LinearLayout>

                    <!-- Avatar + name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="8dp">

                        <ImageView
                            android:id="@+id/ivManagerAvatar"
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:src="@drawable/ic_default_avatar"
                            android:background="@drawable/bg_circle_white"
                            android:scaleType="centerCrop"
                            android:padding="3dp"
                            android:contentDescription="Profile photo"/>

                        <TextView
                            android:id="@+id/tvManagerName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Manager Name"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_bold"/>

                        <TextView
                            android:id="@+id/tvManagerTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Senior Event Manager"
                            android:textColor="#E8DEFF"
                            android:textSize="13sp"
                            android:fontFamily="@font/dm_sans"/>

                        <!-- Location row -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_navigate"
                                app:tint="#E8DEFF"/>

                            <TextView
                                android:id="@+id/tvManagerLocation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="New Delhi, IND"
                                android:textColor="#E8DEFF"
                                android:textSize="12sp"
                                android:fontFamily="@font/dm_sans"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Edit / Share buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="20dp"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_edit_profile"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="10dp"
                            android:text="Edit Profile"
                            android:textSize="13sp"
                            android:textColor="#9381FF"
                            android:fontFamily="@font/dm_sans"
                            app:backgroundTint="#FFFFFF"
                            app:cornerRadius="20dp"/>

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="Share"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:fontFamily="@font/dm_sans"
                            app:strokeColor="#FFFFFF"
                            app:cornerRadius="20dp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- ── SPECIALISATION ─────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Specialization"
                        android:textSize="15sp"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginBottom="12dp"/>

                    <!-- Chip row — filled dynamically -->
                    <LinearLayout
                        android:id="@+id/llSpecialisations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"/>

                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#EEEEEE" android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>

                <!-- ── BIO ────────────────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="About"
                        android:textSize="15sp"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvManagerBio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Bio loads here..."
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:fontFamily="@font/dm_sans"
                        android:lineSpacingMultiplier="1.6"/>

                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#EEEEEE" android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>

                <!-- ── SOCIALS ─────────────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Socials"
                        android:textSize="15sp"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                            android:text="Instagram" android:textSize="13sp" android:textColor="#888888"
                            android:fontFamily="@font/dm_sans"/>
                        <TextView android:id="@+id/tvInstagram"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="13sp" android:textColor="#9381FF"
                            android:fontFamily="@font/dm_sans"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                            android:text="LinkedIn" android:textSize="13sp" android:textColor="#888888"
                            android:fontFamily="@font/dm_sans"/>
                        <TextView android:id="@+id/tvLinkedin"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="13sp" android:textColor="#9381FF"
                            android:fontFamily="@font/dm_sans"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                            android:text="Website" android:textSize="13sp" android:textColor="#888888"
                            android:fontFamily="@font/dm_sans"/>
                        <TextView android:id="@+id/tvWebsite"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="13sp" android:textColor="#9381FF"
                            android:fontFamily="@font/dm_sans"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#EEEEEE" android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>

                <!-- ── PORTFOLIO ───────────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Portfolio"
                            android:textSize="15sp"
                            android:textColor="#1A1A2E"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View All"
                            android:textSize="13sp"
                            android:textColor="#9381FF"
                            android:fontFamily="@font/dm_sans"/>

                    </LinearLayout>

                    <!-- Grid built programmatically -->
                    <LinearLayout
                        android:id="@+id/llPortfolioGrid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── BOTTOM NAV ─────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/managerBottomNav"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:elevation="8dp">

            <!-- Dashboard -->
            <LinearLayout android:id="@+id/nav_dashboard"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_home" app:tint="#BBBBBB"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Home" android:textSize="10sp" android:textColor="#BBBBBB"
                    android:fontFamily="@font/dm_sans" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Profile (current) -->
            <LinearLayout android:id="@+id/nav_profile"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_person" app:tint="#9381FF"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Profile" android:textSize="10sp" android:textColor="#9381FF"
                    android:fontFamily="@font/dm_sans" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Notifications -->
            <LinearLayout android:id="@+id/nav_notifications"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@drawable/ic_notifications" app:tint="#BBBBBB"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Alerts" android:textSize="10sp" android:textColor="#BBBBBB"
                    android:fontFamily="@font/dm_sans" android:layout_marginTop="2dp"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- ═══════════════════ SIDEBAR ════════════════════════════════ -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/white"
        app:headerLayout="@layout/manager_nav_header"
        app:menu="@menu/manager_sidebar_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>