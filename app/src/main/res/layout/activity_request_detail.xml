<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F8F8">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#9381FF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back to Requests"
            android:textSize="16sp"
            android:textColor="#9381FF"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginStart="12dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_menu"
            app:tint="#000000"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- SUMMARY CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvCategory"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Wedding"
                            android:textColor="#9381FF"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_semibold"/>

                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="New Request"
                            android:textColor="#27AE60"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_semibold"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sarah &amp; Michael's Dream Wedding"
                        android:textColor="#1A1A2E"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_bold"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_event"
                            app:tint="#9381FF"/>
                        <TextView
                            android:id="@+id/tvDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="June 15, 2024"
                            android:textColor="#666666"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/dm_sans"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_bookmark"
                            app:tint="#9381FF"/>
                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Downtown Hotel, NYC"
                            android:textColor="#666666"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/dm_sans"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_person"
                            app:tint="#9381FF"/>
                        <TextView
                            android:id="@+id/tvGuests"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="150 guests"
                            android:textColor="#666666"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/dm_sans"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Budget Range"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:layout_gravity="end"
                        android:fontFamily="@font/dm_sans"/>

                    <TextView
                        android:id="@+id/tvBudget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INR 15,00,000 - 20,00,000"
                        android:textColor="#9381FF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_gravity="end"
                        android:fontFamily="@font/poppins_bold"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- EVENT DESCRIPTION CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Event Description"
                        android:textColor="#1A1A2E"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_bold"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="We're planning our dream wedding and looking for an experienced event manager to help us create the perfect day..."
                        android:textColor="#555555"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"
                        android:fontFamily="@font/dm_sans"
                        android:layout_marginBottom="20dp"/>

                    <!-- DETAILS GRID -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Event Type -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="#E8EAF6"
                            android:padding="12dp"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Event Type"
                                android:textColor="#1A1A2E"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/poppins_bold"/>
                            <TextView
                                android:id="@+id/tvEventType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Wedding Reception"
                                android:textColor="#666666"
                                android:textSize="14sp"
                                android:fontFamily="@font/dm_sans"/>
                        </LinearLayout>

                        <!-- Duration -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="#E8EAF6"
                            android:padding="12dp"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Duration"
                                android:textColor="#1A1A2E"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/poppins_bold"/>
                            <TextView
                                android:id="@+id/tvDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8 hours (2 PM - 10 PM)"
                                android:textColor="#666666"
                                android:textSize="14sp"
                                android:fontFamily="@font/dm_sans"/>
                        </LinearLayout>

                        <!-- Style -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="#E8EAF6"
                            android:padding="12dp"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Style"
                                android:textColor="#1A1A2E"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/poppins_bold"/>
                            <TextView
                                android:id="@+id/tvStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Elegant Garden Theme"
                                android:textColor="#666666"
                                android:textSize="14sp"
                                android:fontFamily="@font/dm_sans"/>
                        </LinearLayout>

                        <!-- Special Requests -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="#E8EAF6"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Special Requests"
                                android:textColor="#1A1A2E"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/poppins_bold"/>
                            <TextView
                                android:id="@+id/tvSpecialRequests"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Live music coordination"
                                android:textColor="#666666"
                                android:textSize="14sp"
                                android:fontFamily="@font/dm_sans"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CLIENT INFORMATION CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Client Information"
                        android:textColor="#1A1A2E"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_bold"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/ivClientAvatar"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/img_manisha"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:id="@+id/tvClientName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Meera"
                                android:textColor="#1A1A2E"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/poppins_bold"/>
                            <TextView
                                android:id="@+id/tvClientTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bride • Member since 2023"
                                android:textColor="#888888"
                                android:textSize="13sp"
                                android:fontFamily="@font/dm_sans"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:fontFamily="@font/dm_sans"
                        android:layout_marginBottom="2dp"/>
                    <TextView
                        android:id="@+id/tvClientEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="meeraaaaaaaaaa@gmail.com"
                        android:textColor="#1A1A2E"
                        android:textSize="14sp"
                        android:fontFamily="@font/dm_sans"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phone"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:fontFamily="@font/dm_sans"
                        android:layout_marginBottom="2dp"/>
                    <TextView
                        android:id="@+id/tvClientPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+91 9314456689"
                        android:textColor="#1A1A2E"
                        android:textSize="14sp"
                        android:fontFamily="@font/dm_sans"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ACTION BUTTONS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendQuote"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Send Quote"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="#9381FF"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_send"
                app:iconGravity="textStart"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccept"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Accept Request"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="#27AE60"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_check_all"
                app:iconGravity="textStart"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDecline"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Decline"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="#4E5969"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_logout"
                app:iconGravity="textStart"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
