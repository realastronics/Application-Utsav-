<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Top bar — same pattern as HomeFragment, EventsFragment -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Utsav"
            android:textSize="26sp"
            android:textColor="#9381FF"
            android:fontFamily="@font/poppins_bold"
            android:textStyle="bold"/>

        <com.google.android.material.button.MaterialButton
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Events"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/dm_sans"
            app:backgroundTint="#9381FF"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_search"
            app:iconTint="#FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_menu"
            android:layout_marginStart="10dp"
            android:scaleType="fitCenter"
            android:contentDescription="Menu"/>

    </LinearLayout>

    <!-- Section title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Saved Managers"
        android:textSize="20sp"
        android:textColor="#1A1A2E"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"/>

    <!-- Empty state — shown when savedList is empty -->
    <LinearLayout
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_bookmark"
            android:alpha="0.25"
            android:contentDescription="No saved managers"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No saved managers yet"
            android:textSize="16sp"
            android:textColor="#AAAAAA"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Tap the bookmark icon on any manager card to save them here."
            android:textSize="13sp"
            android:textColor="#BBBBBB"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"/>

    </LinearLayout>

    <!-- Saved manager list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSaved"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:visibility="gone"/>

</LinearLayout>