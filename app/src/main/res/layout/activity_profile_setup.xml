<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F6FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- ── PURPLE HERO BAND ───────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#7C5CBF"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingBottom="32dp">

            <!-- Skip -->
            <TextView
                android:id="@+id/btn_skip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="Skip for now →"
                android:textColor="#E8DEFF"
                android:textSize="13sp"
                android:fontFamily="@font/dm_sans"
                android:paddingBottom="12dp"/>

            <!-- Avatar placeholder -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:src="@drawable/ic_default_avatar"
                    android:background="@drawable/bg_circle_white"
                    android:scaleType="centerCrop"
                    android:padding="3dp"
                    android:contentDescription="Profile photo"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Tap to add photo"
                    android:textColor="#E8DEFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/dm_sans"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Set up your manager profile"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Let event hosts discover and trust you"
                android:textColor="#E8DEFF"
                android:textSize="13sp"
                android:fontFamily="@font/dm_sans"/>

        </LinearLayout>

        <!-- ── FORM CARD ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp">

            <!-- SECTION: About you -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About you"
                android:textSize="15sp"
                android:textColor="#1A1A2E"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="12dp"/>

            <!-- Bio -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Short bio — e.g. 10+ years managing weddings in Mumbai"
                android:layout_marginBottom="14dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF"
                app:hintTextColor="#9381FF"
                app:counterEnabled="true"
                app:counterMaxLength="200">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_bio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:maxLines="5"
                    android:gravity="top|start"
                    android:inputType="textMultiLine|textCapSentences"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Location -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="City / Base location"
                android:layout_marginBottom="14dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF"
                app:hintTextColor="#9381FF"
                app:startIconDrawable="@drawable/ic_navigate"
                app:startIconTint="#9381FF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPostalAddress"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact number"
                android:layout_marginBottom="24dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF"
                app:hintTextColor="#9381FF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- SECTION: Specialisation -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Specialisation"
                android:textSize="15sp"
                android:textColor="#1A1A2E"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <CheckBox android:id="@+id/cb_wedding"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Weddings"
                    android:textSize="13sp" android:textColor="#333333"
                    android:fontFamily="@font/dm_sans" android:buttonTint="#9381FF"/>
                <CheckBox android:id="@+id/cb_corporate"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Corporate"
                    android:textSize="13sp" android:textColor="#333333"
                    android:fontFamily="@font/dm_sans" android:buttonTint="#9381FF"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <CheckBox android:id="@+id/cb_birthday"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Birthdays"
                    android:textSize="13sp" android:textColor="#333333"
                    android:fontFamily="@font/dm_sans" android:buttonTint="#9381FF"/>
                <CheckBox android:id="@+id/cb_concert"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Concerts"
                    android:textSize="13sp" android:textColor="#333333"
                    android:fontFamily="@font/dm_sans" android:buttonTint="#9381FF"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">
                <CheckBox android:id="@+id/cb_conference"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Conferences"
                    android:textSize="13sp" android:textColor="#333333"
                    android:fontFamily="@font/dm_sans" android:buttonTint="#9381FF"/>
                <CheckBox android:id="@+id/cb_private"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Private Parties"
                    android:textSize="13sp" android:textColor="#333333"
                    android:fontFamily="@font/dm_sans" android:buttonTint="#9381FF"/>
            </LinearLayout>

            <!-- SECTION: Socials -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Socials &amp; links"
                android:textSize="15sp"
                android:textColor="#1A1A2E"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Instagram handle (e.g. @yourname)"
                android:layout_marginBottom="12dp"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF" app:hintTextColor="#9381FF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_instagram"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="text" android:fontFamily="@font/dm_sans" android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="LinkedIn profile URL"
                android:layout_marginBottom="12dp"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF" app:hintTextColor="#9381FF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_linkedin"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textUri" android:fontFamily="@font/dm_sans" android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Personal / company website"
                android:layout_marginBottom="24dp"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF" app:hintTextColor="#9381FF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_website"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textUri" android:fontFamily="@font/dm_sans" android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- SECTION: Portfolio image links -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Portfolio image links"
                android:textSize="15sp"
                android:textColor="#1A1A2E"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paste direct image URLs from Google Drive, Dropbox or any CDN"
                android:textSize="12sp"
                android:textColor="#888888"
                android:fontFamily="@font/dm_sans"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Image URL 1"
                android:layout_marginBottom="10dp"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF" app:hintTextColor="#9381FF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_portfolio_url_1"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textUri" android:fontFamily="@font/dm_sans" android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Image URL 2"
                android:layout_marginBottom="10dp"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF" app:hintTextColor="#9381FF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_portfolio_url_2"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textUri" android:fontFamily="@font/dm_sans" android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Image URL 3"
                android:layout_marginBottom="28dp"
                app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF" app:hintTextColor="#9381FF">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_portfolio_url_3"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textUri" android:fontFamily="@font/dm_sans" android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_profile"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Save and continue"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/dm_sans"
                android:textStyle="bold"
                app:backgroundTint="#9381FF"
                app:cornerRadius="14dp"
                android:layout_marginBottom="8dp"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="#9381FF"
                android:visibility="gone"/>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>