<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══════════════════════ MAIN CONTENT ═══════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F6FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ── TOP BAR ─────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Utsav"
                    android:textSize="26sp"
                    android:textColor="#9381FF"
                    android:fontFamily="@font/poppins_bold"
                    android:textStyle="bold"/>

                <!-- Notification bell (wire to ManagerNotificationsActivity later) -->
                <ImageView
                    android:id="@+id/btnNotifications"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_notifications"
                    android:layout_marginEnd="12dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="Notifications"/>

                <ImageView
                    android:id="@+id/btnMenu"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_menu"
                    android:scaleType="fitCenter"
                    android:contentDescription="Menu"/>

            </LinearLayout>

            <!-- ── GREETING BAND ───────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#EEF0FF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hi there!"
                    android:textSize="24sp"
                    android:textColor="#1A1A2E"
                    android:fontFamily="@font/poppins_bold"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Here's your dashboard overview"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:fontFamily="@font/dm_sans"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <!-- ── PERFORMANCE CARDS ───────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Performance"
                android:textSize="16sp"
                android:textColor="#1A1A2E"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Revenue card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#9381FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monthly Revenue"
                            android:textSize="12sp"
                            android:textColor="#E8DEFF"
                            android:fontFamily="@font/dm_sans"/>

                        <TextView
                            android:id="@+id/tvRevenue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INR 0"
                            android:textSize="18sp"
                            android:textColor="#FFFFFF"
                            android:fontFamily="@font/poppins_bold"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Active Bookings card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#9381FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active Bookings"
                            android:textSize="12sp"
                            android:textColor="#E8DEFF"
                            android:fontFamily="@font/dm_sans"/>

                        <TextView
                            android:id="@+id/tvActiveBookings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="32sp"
                            android:textColor="#FFFFFF"
                            android:fontFamily="@font/poppins_bold"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── PENDING REQUESTS ────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pending Requests"
                    android:textSize="16sp"
                    android:textColor="#1A1A2E"
                    android:fontFamily="@font/poppins_semibold"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvPendingCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#9381FF"
                    android:fontFamily="@font/dm_sans"/>

            </LinearLayout>

            <!-- Empty state for requests -->
            <TextView
                android:id="@+id/emptyRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No pending requests 🎉"
                android:textSize="14sp"
                android:textColor="#AAAAAA"
                android:fontFamily="@font/dm_sans"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"/>

            <!-- ── SCHEDULE ────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Schedule"
                android:textSize="16sp"
                android:textColor="#1A1A2E"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"/>

            <!-- Empty state for schedule -->
            <TextView
                android:id="@+id/emptySchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No upcoming events"
                android:textSize="14sp"
                android:textColor="#AAAAAA"
                android:fontFamily="@font/dm_sans"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ═══════════════════════ SIDEBAR ════════════════════════════ -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/white"
        app:headerLayout="@layout/manager_nav_header"
        app:menu="@menu/manager_sidebar_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>