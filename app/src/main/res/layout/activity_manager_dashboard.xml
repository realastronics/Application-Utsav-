<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/dashboard_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ── TOP BAR ─────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Utsav"
                    android:textSize="26sp"
                    android:textColor="#9381FF"
                    android:fontFamily="@font/poppins_bold"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/btnMenu"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_menu"
                    android:scaleType="fitCenter"
                    android:contentDescription="Menu"/>

            </LinearLayout>

            <!-- ── GREETING ─────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Morning,"
                        android:textSize="14sp"
                        android:textColor="#888888"
                        android:fontFamily="@font/dm_sans"/>

                    <TextView
                        android:id="@+id/tvManagerNameDisplay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Utsav Manager"
                        android:textSize="22sp"
                        android:textColor="#111111"
                        android:fontFamily="@font/poppins_bold"
                        android:textStyle="bold"/>
                </LinearLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivManagerProfile"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_person"
                    android:padding="8dp"
                    android:background="#F0EEFF"
                    app:tint="#9381FF"
                    app:shapeAppearanceOverlay="@style/CircleShapeOverlay"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="20dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Performance"
                android:textSize="24sp"
                android:textColor="#111111"
                android:fontFamily="@font/poppins_bold"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <!-- Revenue card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_insights"
                            android:padding="6dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="#F0EEFF"
                            app:tint="#9381FF"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Revenue"
                            android:textSize="13sp"
                            android:textColor="#888888"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/dm_sans"/>

                        <TextView
                            android:id="@+id/tvRevenue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INR 0"
                            android:textSize="18sp"
                            android:textColor="#111111"
                            android:fontFamily="@font/poppins_bold"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Active Bookings card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_event"
                            android:padding="6dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:backgroundTint="#F0EEFF"
                            app:tint="#9381FF"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bookings"
                            android:textSize="13sp"
                            android:textColor="#888888"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/dm_sans"/>

                        <TextView
                            android:id="@+id/tvActiveBookings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="18sp"
                            android:textColor="#111111"
                            android:fontFamily="@font/poppins_bold"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ── PENDING REQUESTS ────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pending Requests"
                    android:textSize="16sp"
                    android:textColor="#1A1A2E"
                    android:fontFamily="@font/poppins_semibold"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvPendingCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#9381FF"
                    android:fontFamily="@font/dm_sans"/>

            </LinearLayout>

            <!-- Empty state for requests -->
            <TextView
                android:id="@+id/emptyRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No pending requests 🎉"
                android:textSize="14sp"
                android:textColor="#AAAAAA"
                android:fontFamily="@font/dm_sans"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

            <!-- ── SCHEDULE ────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Schedule"
                android:textSize="16sp"
                android:textColor="#1A1A2E"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"/>

            <!-- Empty state for schedule -->
            <TextView
                android:id="@+id/emptySchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No upcoming events"
                android:textSize="14sp"
                android:textColor="#AAAAAA"
                android:fontFamily="@font/dm_sans"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

    </FrameLayout>
        <!-- ── MANAGER BOTTOM NAV ──────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/managerBottomNav"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:elevation="12dp"
                android:gravity="center_vertical">

                <!-- Home -->
                <LinearLayout
                    android:id="@+id/mnav_dashboard"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/mnav_dashboard_icon"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_home"
                        app:tint="#9381FF"/>
                </LinearLayout>

                <!-- Requests -->
                <LinearLayout
                    android:id="@+id/mnav_requests"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/mnav_requests_icon"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_request_list"
                        app:tint="#BBBBBB"/>
                </LinearLayout>

                <!-- Insights (Now in line) -->
                <LinearLayout
                    android:id="@+id/mnav_insights"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/mnav_insights_icon"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_insights"
                        app:tint="#BBBBBB"/>
                </LinearLayout>

                <!-- Chat -->
                <LinearLayout
                    android:id="@+id/mnav_chat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/mnav_chat_icon"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_chat"
                        app:tint="#BBBBBB"/>
                </LinearLayout>

                <!-- Profile -->
                <LinearLayout
                    android:id="@+id/mnav_profile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/mnav_profile_icon"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_person"
                        app:tint="#BBBBBB"/>
                </LinearLayout>

            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- ═══════════════════════ SIDEBAR ════════════════════════════ -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/white"
        app:headerLayout="@layout/manager_nav_header"
        app:menu="@menu/manager_sidebar_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>