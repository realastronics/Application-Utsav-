<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- ── TOP BAR ─────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Utsav"
                android:textSize="26sp"
                android:textColor="#9381FF"
                android:fontFamily="@font/poppins_bold"
                android:textStyle="bold"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Events"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/dm_sans"
                app:backgroundTint="#9381FF"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_search"
                app:iconTint="#FFFFFF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_menu"
                android:layout_marginStart="10dp"
                android:scaleType="fitCenter"
                android:contentDescription="Menu"/>

        </LinearLayout>

        <!-- ── PURPLE SECTION HEADER ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#EEF0FF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Event"
                android:textSize="22sp"
                android:textColor="#111111"
                android:fontFamily="@font/poppins_bold"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill in your event requirements below"
                android:textSize="13sp"
                android:textColor="#666666"
                android:fontFamily="@font/dm_sans"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- ── FORM CARD ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp">

            <!-- ── Event Title ──────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Title *"
                android:textSize="13sp"
                android:textColor="#333333"
                android:fontFamily="@font/dm_sans"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_event_title"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="e.g., Corporate Annual Gala"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF"
                app:hintTextColor="#9381FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_event_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Event Type ───────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Type *"
                android:textSize="13sp"
                android:textColor="#333333"
                android:fontFamily="@font/dm_sans"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeCorporate"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="🏢  Corporate"
                    android:textSize="13sp"
                    android:fontFamily="@font/dm_sans"
                    app:cornerRadius="10dp"
                    app:strokeColor="#9381FF"
                    android:textColor="#9381FF"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeWedding"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="💍  Wedding"
                    android:textSize="13sp"
                    android:fontFamily="@font/dm_sans"
                    app:cornerRadius="10dp"
                    app:strokeColor="#9381FF"
                    android:textColor="#9381FF"/>

            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeBirthday"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="🎂  Birthday"
                    android:textSize="13sp"
                    android:fontFamily="@font/dm_sans"
                    app:cornerRadius="10dp"
                    app:strokeColor="#9381FF"
                    android:textColor="#9381FF"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTypeConcert"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="🎵  Concert"
                    android:textSize="13sp"
                    android:fontFamily="@font/dm_sans"
                    app:cornerRadius="10dp"
                    app:strokeColor="#9381FF"
                    android:textColor="#9381FF"/>

            </LinearLayout>

            <!-- ── Description ──────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description *"
                android:textSize="13sp"
                android:textColor="#333333"
                android:fontFamily="@font/dm_sans"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_description"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Describe your event requirements in detail..."
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF"
                app:hintTextColor="#9381FF"
                app:counterEnabled="true"
                app:counterMaxLength="500">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="4"
                    android:maxLines="6"
                    android:gravity="top|start"
                    android:inputType="textMultiLine|textCapSentences"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Min 50 characters"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:fontFamily="@font/dm_sans"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp"/>

            <!-- ── Event Date ────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Date *"
                android:textSize="13sp"
                android:textColor="#333333"
                android:fontFamily="@font/dm_sans"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_event_date"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="mm/dd/yyyy"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF"
                app:hintTextColor="#9381FF"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_event"
                app:endIconTint="#9381FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_event_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:cursorVisible="false"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Event Time ────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Time *"
                android:textSize="13sp"
                android:textColor="#333333"
                android:fontFamily="@font/dm_sans"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_event_time"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="-- : -- --"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF"
                app:hintTextColor="#9381FF"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_notifications"
                app:endIconTint="#9381FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_event_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:cursorVisible="false"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Location ─────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location *"
                android:textSize="13sp"
                android:textColor="#333333"
                android:fontFamily="@font/dm_sans"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_location"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="Enter city or venue"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF"
                app:hintTextColor="#9381FF"
                app:startIconDrawable="@drawable/ic_navigate"
                app:startIconTint="#9381FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPostalAddress"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Expected Audience ─────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expected Audience *"
                android:textSize="13sp"
                android:textColor="#333333"
                android:fontFamily="@font/dm_sans"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_audience"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="e.g., 200"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF"
                app:hintTextColor="#9381FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_audience"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Budget Range ──────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Budget Range *"
                android:textSize="13sp"
                android:textColor="#333333"
                android:fontFamily="@font/dm_sans"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_budget"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="Select budget"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#9381FF"
                app:hintTextColor="#9381FF">

                <AutoCompleteTextView
                    android:id="@+id/actvBudget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:inputType="none"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Services Needed ──────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Services Needed"
                android:textSize="13sp"
                android:textColor="#333333"
                android:fontFamily="@font/dm_sans"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <CheckBox
                    android:id="@+id/cbDJ"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DJ"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:fontFamily="@font/dm_sans"
                    android:buttonTint="#9381FF"/>

                <CheckBox
                    android:id="@+id/cbLiveBand"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Live Band"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:fontFamily="@font/dm_sans"
                    android:buttonTint="#9381FF"/>

            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <CheckBox
                    android:id="@+id/cbCatering"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Catering"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:fontFamily="@font/dm_sans"
                    android:buttonTint="#9381FF"/>

                <CheckBox
                    android:id="@+id/cbDecoration"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Decoration"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:fontFamily="@font/dm_sans"
                    android:buttonTint="#9381FF"/>

            </LinearLayout>

            <!-- Row 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <CheckBox
                    android:id="@+id/cbPhotography"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Photography"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:fontFamily="@font/dm_sans"
                    android:buttonTint="#9381FF"/>

                <CheckBox
                    android:id="@+id/cbVideography"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Videography"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:fontFamily="@font/dm_sans"
                    android:buttonTint="#9381FF"/>

            </LinearLayout>

            <!-- ── Visibility ────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visibility"
                android:textSize="13sp"
                android:textColor="#333333"
                android:fontFamily="@font/dm_sans"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <RadioGroup
                android:id="@+id/rgVisibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="28dp">

                <!-- Public Listing -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/rbPublic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:buttonTint="#9381FF"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Public Listing"
                            android:textSize="14sp"
                            android:textColor="#1A1A2E"
                            android:fontFamily="@font/dm_sans"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All managers can see and quote"
                            android:textSize="12sp"
                            android:textColor="#888888"
                            android:fontFamily="@font/dm_sans"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Invite Only -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <RadioButton
                        android:id="@+id/rbInviteOnly"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#9381FF"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Invite Only"
                            android:textSize="14sp"
                            android:textColor="#1A1A2E"
                            android:fontFamily="@font/dm_sans"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select specific managers"
                            android:textSize="12sp"
                            android:textColor="#888888"
                            android:fontFamily="@font/dm_sans"/>

                    </LinearLayout>

                </LinearLayout>

            </RadioGroup>

            <!-- ── Submit Button ─────────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPostEvent"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Post Event"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/dm_sans"
                android:textStyle="bold"
                app:backgroundTint="#9381FF"
                app:cornerRadius="14dp"
                android:layout_marginBottom="8dp"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="#9381FF"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>