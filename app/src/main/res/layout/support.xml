<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F7F7">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tvLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Utsav"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#9381FF"
            android:layout_centerVertical="true" />

        <ImageView
            android:id="@+id/menuIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="#000000"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- HELP CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#E6E0FF"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Need Help?"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#111111"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Our dedicated team is here to help you manage your events seamlessly."
                    android:textSize="15sp"
                    android:textColor="#666666"
                    android:layout_marginTop="10dp"/>

                <Button
                    android:id="@+id/btnSupport"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="+ Raise a Support Request"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#111111"
                    android:layout_marginTop="18dp"
                    android:backgroundTint="#9381FF"/>
            </LinearLayout>

            <!-- RECENT TICKETS -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Tickets"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#111111"/>

                <TextView
                    android:id="@+id/tvViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All"
                    android:textColor="#9381FF"
                    android:textSize="14sp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <!-- TICKET 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:text="#TK-8921"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:text="Confirmation issue"
                        android:textSize="20sp"
                        android:textColor="#111111"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="● PENDING"
                        android:textColor="#7F6BFD"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <TextView
                    android:text="Updated 2 hours ago"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- TICKET 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:layout_marginTop="12dp"
                android:elevation="2dp">

                <TextView
                    android:text="#TK-8845"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:text="Manager issue"
                        android:textSize="20sp"
                        android:textColor="#111111"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="● RESOLVED"
                        android:textColor="#7F6BFD"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <TextView
                    android:text="Closed 1 day ago"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- TICKET 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="#FFFFFF"
                android:layout_marginTop="12dp"
                android:elevation="2dp">

                <TextView
                    android:text="#TK-8712"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:text="User issue"
                        android:textSize="20sp"
                        android:textColor="#111111"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="● PENDING"
                        android:textColor="#7F6BFD"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <TextView
                    android:text="Updated 3 days ago"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- CONTACT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact Us"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_marginTop="20dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btnEmail"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:text="✉\nEmail Support"
                    android:textAllCaps="false"
                    android:textColor="#111111"
                    android:textStyle="bold"
                    android:background="##9381FF
">

                <Button
                    android:id="@+id/btnChat"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="💬\nLive Chat"
                    android:textAllCaps="false"
                    android:textColor="#111111"
                    android:textStyle="bold"
                    android:backgroundTint="#FFFFFF"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⌂"
            android:textColor="#7F6BFD"
            android:textSize="24sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="❔"
            android:textColor="#7F6BFD"
            android:textSize="24sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊"
            android:textSize="24sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💬"
            android:textColor="#7F6BFD"
            android:textSize="24sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👤"
            android:textColor="#7F6BFD"
            android:textSize="24sp"
            android:gravity="center"/>
    </LinearLayout>

</LinearLayout>