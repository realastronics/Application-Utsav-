<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ==================== TOP APP BAR ==================== -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_alignParentTop="true">

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Utsav"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#7C5CBF"
            android:fontFamily="serif"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_menu"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Menu"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:tint="#1A1A2E" />
    </RelativeLayout>

    <!-- ==================== BOTTOM NAV ==================== -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_home"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Home"
            android:tint="#BDBDBD" />

        <ImageButton
            android:id="@+id/navRequests"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_requests"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Requests"
            android:tint="#BDBDBD" />

        <ImageButton
            android:id="@+id/navStats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_stats"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Stats"
            android:tint="#7C5CBF" />

        <ImageButton
            android:id="@+id/navChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_chat"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Chat"
            android:tint="#BDBDBD" />

        <ImageButton
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_profile"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Profile"
            android:tint="#BDBDBD" />
    </LinearLayout>

    <!-- ==================== SCROLLABLE CONTENT ==================== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@id/bottomNav"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp">

            <!-- Page title row with back arrow -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Back"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:tint="#1A1A2E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Promotion And Visibility"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_centerInParent="true" />
            </RelativeLayout>

            <!-- ===== BOOST CARD ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBoost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EDE7F6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_horizontal">

                    <!-- Rocket icon in purple circle -->
                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/circle_solid_purple" />

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_rocket"
                            android:layout_gravity="center"
                            android:tint="#FFFFFF"
                            android:contentDescription="Boost" />
                    </FrameLayout>

                    <!-- Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Boost Your Reach"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="4dp" />

                    <!-- Price -->
                    <TextView
                        android:id="@+id/tvPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INR 80 /month"
                        android:textSize="14sp"
                        android:textColor="#757575"
                        android:layout_marginBottom="20dp" />

                    <!-- Feature list -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp">

                        <!-- Feature 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_check_circle"
                                android:tint="#7C5CBF"
                                android:layout_marginEnd="10dp"
                                android:contentDescription="Check" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Priority in Search result"
                                android:textSize="14sp"
                                android:textColor="#1A1A2E" />
                        </LinearLayout>

                        <!-- Feature 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_check_circle"
                                android:tint="#7C5CBF"
                                android:layout_marginEnd="10dp"
                                android:contentDescription="Check" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Higher Table Placement"
                                android:textSize="14sp"
                                android:textColor="#1A1A2E" />
                        </LinearLayout>

                        <!-- Feature 3 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_check_circle"
                                android:tint="#7C5CBF"
                                android:layout_marginEnd="10dp"
                                android:contentDescription="Check" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Suggested to organisers"
                                android:textSize="14sp"
                                android:textColor="#1A1A2E" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Subscribe Now Button -->
                    <Button
                        android:id="@+id/btnSubscribe"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Subscribe Now"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#7C5CBF"
                        app:cornerRadius="24dp"
                        android:layout_marginBottom="12dp" />

                    <!-- Cancel anytime text -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cancel anytime , Terms and conditions applied"
                        android:textSize="11sp"
                        android:textColor="#9E9E9E"
                        android:gravity="center" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== VISIBILITY STATUS CARD ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardVisibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header row -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Visibility Status"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E" />

                        <ImageView
                            android:id="@+id/ivVisibilityEye"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_visibility"
                            android:tint="#7C5CBF"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:contentDescription="Visibility" />
                    </RelativeLayout>

                    <!-- Current tier label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT TIER: FREE"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:textColor="#9E9E9E"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="10dp" />

                    <!-- Reach row -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Reach"
                            android:textSize="13sp"
                            android:textColor="#1A1A2E" />

                        <TextView
                            android:id="@+id/tvPotential"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+350% potential"
                            android:textSize="13sp"
                            android:textColor="#7C5CBF"
                            android:textStyle="bold"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <!-- Progress bar -->
                    <ProgressBar
                        android:id="@+id/progressReach"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:max="100"
                        android:progress="22"
                        android:progressDrawable="@drawable/progress_reach"
                        android:layout_marginBottom="6dp" />

                    <!-- Free / PRO Reach labels -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Free"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PRO Reach"
                            android:textSize="11sp"
                            android:textColor="#7C5CBF"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <!-- Info row with stats icon -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_stats"
                            android:tint="#7C5CBF"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="Stats" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Managers with PRO visibility receive an average of 4.2x more booking inquiries"
                            android:textSize="12sp"
                            android:textColor="#757575" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>